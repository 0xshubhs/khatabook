# Copy to .env and adjust. Each app also has its own .env.example.

# --- Database (Phase 1) ---
DATABASE_URL="postgresql://khatabook:khatabook@localhost:5432/khatabook?schema=public"

# --- Backend (Phase 2) --- runs on 4000 (nginx exposes it at propexty.com/api)
PORT=4000
JWT_ACCESS_SECRET="dev-access-secret-change-me"
JWT_REFRESH_SECRET="dev-refresh-secret-change-me"
WEBAPP_ORIGIN="http://localhost:3000"

# --- Webapp (Phase 3) ---
NEXT_PUBLIC_API_URL="http://localhost:4000"

# --- RN shell (Phase 6) ---
EXPO_PUBLIC_WEBAPP_URL="http://localhost:3000"
